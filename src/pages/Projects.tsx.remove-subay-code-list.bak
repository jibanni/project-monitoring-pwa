      <path d="M10.8 4.2a6.6 6.6 0 1 0 0 13.2 6.6 6.6 0 0 0 0-13.2Zm0 2a4.6 4.6 0 1 1 0 9.2 4.6 4.6 0 0 1 0-9.2Zm5.2 10.6 3.4 3.4a1 1 0 0 0 1.4-1.4l-3.4-3.4a1 1 0 0 0-1.4 1.4Z" />
    </svg>
  )
}


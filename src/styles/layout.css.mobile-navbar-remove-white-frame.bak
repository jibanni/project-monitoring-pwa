:root {
  --app-blue-950: #06234a;
  --app-blue-900: #082f60;
  --app-blue-800: #0f477f;
  --app-blue-700: #155da4;
  --app-blue-600: #1d6ec2;
  --app-orange: #f97316;
  --app-orange-dark: #ea580c;
  --app-text: #0f172a;
  --app-muted: #64748b;
  --app-border: rgba(148, 163, 184, 0.28);
  --app-bg: #eef4fb;
  --app-card: #ffffff;
  --app-header-h: 82px;
  --app-page-pad: 24px;
  --app-bottom-nav-h: 78px;
  --app-header-gradient:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.16), transparent 36%),
    linear-gradient(135deg, #082f60 0%, #0f477f 54%, #1d6ec2 100%);
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  width: 100%;
  min-height: 100%;
  margin: 0;
  padding: 0;
  overflow-x: hidden;
  background: var(--app-bg);
}

html {
  scroll-behavior: auto;
  overscroll-behavior-y: none;
}

body {
  background:
    radial-gradient(circle at top left, rgba(29, 110, 194, 0.12), transparent 32%),
    linear-gradient(180deg, #f7fbff 0%, #edf4fb 48%, #e8f0f8 100%);
  color: var(--app-text);
  font-family:
    Inter,
    ui-sans-serif,
    system-ui,
    -apple-system,
    BlinkMacSystemFont,
    "Segoe UI",
    sans-serif;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

button,
input,
select,
textarea {
  font: inherit;
}

button,
a {
  -webkit-tap-highlight-color: transparent;
}

button {
  touch-action: manipulation;
}

a {
  color: inherit;
  text-decoration: none;
}

img,
svg {
  display: block;
}

.app-shell,
.app-main,
.app-content,
.main-content,
.page-content {
  transform: none !important;
  filter: none !important;
  perspective: none !important;
  contain: none !important;
}

/* =========================
   SHELL
========================= */

.app-shell {
  min-height: 100vh;
  padding-top: var(--app-header-live-h, var(--app-header-h));
  padding-bottom: 24px;
  --current-header-h: var(--app-header-h);
}

.app-shell.app-scrolled {
  --current-header-h: 64px;
}

/* =========================
   TOP HEADER
========================= */

.app-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 99990;

  width: 100%;
  min-height: var(--current-header-h);
  padding: 12px var(--app-page-pad);

  background: var(--app-header-gradient);
  border-bottom: 0;
  border-radius: 0;
  box-shadow: 0 12px 32px rgba(15, 23, 42, 0.18);

  transform: none;
  translate: none;
  backface-visibility: hidden;

  transition:
    min-height 0.18s ease,
    padding 0.18s ease,
    box-shadow 0.18s ease;
}

.app-scrolled .app-header {
  padding-top: 8px;
  padding-bottom: 8px;
  box-shadow: 0 10px 26px rgba(15, 23, 42, 0.13);
}

.app-header-inner {
  width: min(1500px, 100%);
  margin: 0 auto;

  display: grid;
  grid-template-columns: minmax(250px, 380px) 1fr auto;
  align-items: center;
  gap: 18px;
}

.app-brand {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12px;
  color: #ffffff;
}

.app-brand-logo-wrap {
  flex: 0 0 auto;
  width: 52px;
  height: 52px;
  display: grid;
  place-items: center;
  border-radius: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
  transition:
    width 0.18s ease,
    height 0.18s ease;
}

.app-scrolled .app-brand-logo-wrap {
  width: 42px;
  height: 42px;
}

.app-brand-logo {
  width: 52px;
  height: 52px;
  object-fit: contain;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  transition:
    width 0.18s ease,
    height 0.18s ease;
}

.app-scrolled .app-brand-logo {
  width: 42px;
  height: 42px;
}

.app-brand-text {
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  line-height: 1.05;
}

.app-brand-title {
  overflow: hidden;
  color: #ffffff;
  font-size: clamp(1rem, 1.4vw, 1.24rem);
  font-weight: 950;
  letter-spacing: 0.055em;
  line-height: 1.05;
  text-overflow: ellipsis;
  text-transform: uppercase;
  white-space: nowrap;
}

.app-brand-subtitle {
  overflow: hidden;
  margin-top: 3px;
  color: rgba(255, 255, 255, 0.94);
  font-size: 0.82rem;
  font-weight: 850;
  letter-spacing: 0.055em;
  line-height: 1.05;
  text-overflow: ellipsis;
  text-transform: uppercase;
  white-space: nowrap;
}

.app-brand-unit {
  overflow: hidden;
  margin-top: 4px;
  color: rgba(255, 255, 255, 0.82);
  font-size: 0.73rem;
  font-weight: 650;
  letter-spacing: 0.025em;
  line-height: 1.05;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition:
    opacity 0.16s ease,
    max-height 0.16s ease,
    margin 0.16s ease;
}

.app-scrolled .app-brand-unit {
  max-height: 0;
  margin-top: 0;
  opacity: 0;
}

/* =========================
   DESKTOP NAV
========================= */

.app-desktop-nav {
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  overflow-x: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.45) rgba(255, 255, 255, 0.12);
}

.app-desktop-nav::-webkit-scrollbar {
  height: 5px;
}

.app-desktop-nav::-webkit-scrollbar-thumb {
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.45);
}

.app-nav-link {
  flex: 0 0 auto;
  min-height: 40px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  border-radius: 999px;
  padding: 9px 12px;
  color: rgba(255, 255, 255, 0.86);
  font-size: 0.82rem;
  font-weight: 850;
  letter-spacing: 0.01em;
  transition:
    background 0.16s ease,
    color 0.16s ease,
    transform 0.16s ease,
    box-shadow 0.16s ease;
}

.app-nav-link:hover {
  transform: translateY(-1px);
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
}

.app-nav-link.active {
  background: #ffffff;
  color: var(--app-blue-800);
  box-shadow: 0 10px 22px rgba(15, 23, 42, 0.2);
}

.app-nav-icon {
  width: 18px;
  height: 18px;
  display: inline-grid;
  place-items: center;
  line-height: 1;
}

.app-nav-icon svg {
  width: 18px;
  height: 18px;
  fill: currentColor;
}

/* =========================
   USER AREA
========================= */

.app-user-area {
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
}

.app-user-avatar {
  width: 42px;
  height: 42px;
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.15);
  color: #ffffff;
  font-size: 0.68rem;
  font-weight: 950;
  letter-spacing: 0.035em;
}

.app-user-text {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  color: #ffffff;
  line-height: 1.05;
}

.app-user-name {
  max-width: 170px;
  overflow: hidden;
  color: #ffffff;
  font-size: 0.82rem;
  font-weight: 850;
  letter-spacing: 0.01em;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.app-user-role {
  margin-top: 3px;
  color: rgba(255, 255, 255, 0.74);
  font-size: 0.68rem;
  font-weight: 850;
  letter-spacing: 0.09em;
  text-transform: uppercase;
}

.app-user-logout-inline {
  display: none;
  margin-top: 4px;
  border: 0;
  padding: 0;
  cursor: pointer;
  background: transparent;
  color: #fecaca;
  font-size: 0.62rem;
  font-weight: 850;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.app-logout-button {
  min-height: 38px;
  border: 0;
  border-radius: 999px;
  padding: 0 14px;
  cursor: pointer;
  background: rgba(239, 68, 68, 0.96);
  color: #ffffff;
  font-size: 0.78rem;
  font-weight: 850;
  box-shadow: 0 10px 20px rgba(127, 29, 29, 0.24);
  transition:
    transform 0.16s ease,
    box-shadow 0.16s ease,
    background 0.16s ease;
}

.app-logout-button:hover {
  transform: translateY(-1px);
  background: #dc2626;
  box-shadow: 0 14px 26px rgba(127, 29, 29, 0.3);
}

/* =========================
   MAIN CONTENT
========================= */

.app-main {
  position: relative;
  z-index: 1;
  width: min(1500px, 100%);
  margin: 0 auto;
  padding: 10px var(--app-page-pad) 34px;
  overflow: visible;
}

.dashboard-page,
.projects-page,
.pm-map-page,
.reports-page,
.offline-sync-page,
.user-management-page,
.create-project-page,
.edit-project-page,
.project-details-page,
.pu-page {
  margin-top: 0;
}

/* =========================
   LOADER
========================= */

.app-page-loader {
  min-height: 52vh;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 12px;
  color: #16467a;
  text-align: center;
}

.app-page-loader-spinner {
  width: 34px;
  height: 34px;
  border: 4px solid rgba(22, 70, 122, 0.16);
  border-top-color: #16467a;
  border-radius: 999px;
  animation: app-page-loader-spin 780ms linear infinite;
}

.app-page-loader p {
  margin: 0;
  font-size: 0.9rem;
  font-weight: 850;
}

@keyframes app-page-loader-spin {
  to {
    transform: rotate(360deg);
  }
}

/* =========================
   MAP / LEAFLET BASE SAFETY
========================= */

.app-map-route .app-main {
  isolation: isolate;
}

.map-wrapper,
.map-container,
.project-map-container,
.pm-map-container,
.gis-map-container,
.leaflet-map-wrapper,
.map-card,
.pm-map-card {
  position: relative;
  z-index: 1;
  overflow: hidden;
  isolation: isolate;
  border-radius: 22px;
}

.leaflet-container {
  position: relative;
  z-index: 1;
}

/* =========================
   MOBILE NAV DEFAULT HIDDEN
========================= */

.app-mobile-nav {
  display: none;
}

/* =========================
   RESPONSIVE DESKTOP/TABLET
========================= */

@media (max-width: 1100px) {
  .app-header-inner {
    grid-template-columns: minmax(220px, 340px) 1fr auto;
    gap: 12px;
  }

  .app-nav-link {
    padding-inline: 10px;
    font-size: 0.78rem;
  }

  .app-user-name {
    max-width: 130px;
  }
}

/* =========================
   REAL PHONE / MOBILE
========================= */

@media (max-width: 900px) {
  :root {
    --app-page-pad: 14px;
    --app-header-h: 74px;
    --app-bottom-nav-h: 78px;
  }

  html,
  body,
  #root {
    min-height: 100%;
    overflow-x: hidden !important;
    background: #eaf2fb;
  }

  .app-shell {
    min-height: 100dvh;
    padding-top: var(--app-header-live-h, 74px);
    padding-bottom: 106px;
    --current-header-h: 74px;
  }

  .app-shell.app-scrolled {
    --current-header-h: 74px;
  }

  .app-header {
    min-height: 74px;
    padding: 9px 12px;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.16);
    transition: none;
    will-change: auto;
  }

  .app-scrolled .app-header {
    padding: 9px 12px;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.16);
  }

  .app-header-inner {
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
  }

  .app-brand {
    gap: 9px;
  }

  .app-brand-logo-wrap,
  .app-brand-logo,
  .app-scrolled .app-brand-logo-wrap,
  .app-scrolled .app-brand-logo {
    width: 46px;
    height: 46px;
  }

  .app-brand-title {
    font-size: 0.88rem;
    letter-spacing: 0.035em;
  }

  .app-brand-subtitle {
    margin-top: 2px;
    font-size: 0.62rem;
    letter-spacing: 0.035em;
  }

  .app-brand-unit {
    display: none;
  }

  .app-desktop-nav {
    display: none;
  }

  .app-user-area {
    gap: 6px;
  }

  .app-user-avatar,
  .app-scrolled .app-user-avatar {
    width: 35px;
    height: 35px;
    font-size: 0.56rem;
    letter-spacing: 0.02em;
  }

  .app-user-text {
    align-items: flex-start;
  }

  .app-user-name {
    display: none;
  }

  .app-user-role {
    margin-top: 0;
    font-size: 0.52rem;
    letter-spacing: 0.07em;
  }

  .app-user-logout-inline {
    display: block;
    margin-top: 4px;
    font-size: 0.5rem;
  }

  .app-logout-button {
    display: none;
  }

  .app-main {
    width: 100%;
    max-width: 1500px;
    padding: 8px var(--app-page-pad) 104px;
  }

  .app-mobile-nav {
    position: fixed;
    left: 10px;
    right: 10px;
    bottom: 6px;
    z-index: 99999;

    display: block;
    height: 74px;
    margin: 0;
    padding: 0;

    pointer-events: auto;
    touch-action: manipulation;

    transform: none;
    translate: none;
    transition: none;
    animation: none;
    will-change: auto;
    backface-visibility: hidden;
  }

  .app-mobile-nav-scroll {
    width: 100%;
    height: 74px;
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 4px;

    padding: 8px 9px;
    border: 1px solid rgba(203, 213, 225, 0.94);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.98);

    box-shadow:
      0 14px 32px rgba(15, 23, 42, 0.22),
      0 5px 12px rgba(15, 23, 42, 0.14);

    overflow: hidden;
    pointer-events: auto;
    transform: none;
    transition: none;
    will-change: auto;
  }

  .app-mobile-nav-item {
    appearance: none;
    -webkit-appearance: none;

    flex: 1 1 0;
    min-width: 0;
    min-height: 56px;
    height: 56px;

    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;

    margin: 0;
    padding: 7px 3px;
    border: 0;
    border-radius: 19px;
    background: transparent;
    color: #334155;

    cursor: pointer;
    pointer-events: auto;
    touch-action: manipulation;
    user-select: none;
    -webkit-user-select: none;

    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.005em;
    line-height: 1;

    transform: none;
    transition: none;
  }

  .app-mobile-nav-item.active {
    background: #fff7ed;
    color: #ea580c;
  }

  .app-mobile-nav-icon {
    width: 23px;
    height: 23px;
    display: grid;
    place-items: center;
    line-height: 1;
  }

  .app-mobile-nav-icon svg {
    width: 23px;
    height: 23px;
    fill: currentColor;
  }

  .app-mobile-nav-label {
    display: block;
    max-width: 100%;
    overflow: hidden;
    font-size: 0.64rem;
    font-weight: 900;
    line-height: 1;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .gis-map-fab-stack,
  .gis-refresh-fab-final,
  .gis-refocus-fab-final,
  .pm-map-refresh-fab,
  .refresh-fab,
  .fab,
  .floating-action-button {
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .dashboard-hero,
  .projects-hero,
  .pm-map-hero,
  .reports-hero,
  .offline-sync-hero,
  .user-management-hero,
  .create-project-hero,
  .edit-project-hero,
  .project-details-hero,
  .pu-hero {
    will-change: auto;
  }
}

@media (max-width: 420px) {
  :root {
    --app-page-pad: 10px;
  }

  .app-header {
    padding-left: 10px;
    padding-right: 10px;
  }

  .app-brand {
    gap: 8px;
  }

  .app-brand-logo-wrap,
  .app-brand-logo,
  .app-scrolled .app-brand-logo-wrap,
  .app-scrolled .app-brand-logo {
    width: 42px;
    height: 42px;
  }

  .app-brand-title {
    font-size: 0.76rem;
    letter-spacing: 0.03em;
  }

  .app-brand-subtitle {
    font-size: 0.54rem;
    letter-spacing: 0.025em;
  }

  .app-user-avatar,
  .app-scrolled .app-user-avatar {
    width: 33px;
    height: 33px;
    font-size: 0.5rem;
  }

  .app-user-role {
    font-size: 0.48rem;
  }

  .app-user-logout-inline {
    font-size: 0.48rem;
  }

  .app-mobile-nav {
    left: 7px;
    right: 7px;
    bottom: 6px;
    height: 72px;
  }

  .app-mobile-nav-scroll {
    height: 72px;
    padding: 7px;
    border-radius: 24px;
  }

  .app-mobile-nav-item {
    height: 55px;
    min-height: 55px;
    border-radius: 17px;
    font-size: 0.58rem;
  }

  .app-mobile-nav-icon,
  .app-mobile-nav-icon svg {
    width: 21px;
    height: 21px;
  }

  .app-mobile-nav-label {
    font-size: 0.59rem;
  }
}

@media (max-width: 360px) {
  .app-brand-title {
    font-size: 0.7rem;
  }

  .app-brand-subtitle {
    font-size: 0.5rem;
  }

  .app-mobile-nav-label {
    font-size: 0.54rem;
  }
}

@media (min-width: 901px) {
  .app-mobile-nav {
    display: none !important;
  }
}
/* =========================================================
   GLOBAL HEADER TOP-LAYER FIX
   Keeps the DILG main banner above all page heroes.
   Paste at the VERY BOTTOM of src/styles/layout.css
   ========================================================= */

.app-header,
.app-scrolled .app-header,
.app-project-details-route .app-header,
.app-project-details-route.app-scrolled .app-header {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;

  z-index: 2147483600 !important;

  width: 100% !important;
  opacity: 1 !important;
  visibility: visible !important;

  transform: none !important;
  translate: none !important;
  will-change: auto !important;
}

/* =========================================================
   PROJECT DETAILS HEADER LOCK
   This only applies on the Project Details route.
   Keep this at the VERY BOTTOM.
   ========================================================= */

.app-shell.app-project-details-route,
.app-shell.app-project-details-route.app-scrolled {
  --pd-safe-top: env(safe-area-inset-top, 0px);
  --pd-locked-header-h: calc(74px + var(--pd-safe-top));
  --current-header-h: var(--pd-locked-header-h) !important;

  padding-top: var(--pd-locked-header-h) !important;
}

.app-shell.app-project-details-route .app-header,
.app-shell.app-project-details-route.app-scrolled .app-header {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;

  z-index: 2147483000 !important;

  width: 100% !important;
  min-height: var(--pd-locked-header-h) !important;
  height: var(--pd-locked-header-h) !important;
  max-height: var(--pd-locked-header-h) !important;

  padding-top: calc(9px + var(--pd-safe-top)) !important;
  padding-bottom: 9px !important;
  padding-left: 12px !important;
  padding-right: 12px !important;

  transform: none !important;
  translate: none !important;
  opacity: 1 !important;
  visibility: visible !important;
  will-change: auto !important;
}

.app-shell.app-project-details-route .app-main,
.app-shell.app-project-details-route.app-scrolled .app-main {
  padding-top: 0 !important;
}

.app-shell.app-project-details-route .app-brand-logo-wrap,
.app-shell.app-project-details-route .app-brand-logo,
.app-shell.app-project-details-route.app-scrolled .app-brand-logo-wrap,
.app-shell.app-project-details-route.app-scrolled .app-brand-logo {
  width: 46px !important;
  height: 46px !important;
  min-width: 46px !important;
  min-height: 46px !important;
  max-width: 46px !important;
  max-height: 46px !important;
}

@media (max-width: 420px) {
  .app-shell.app-project-details-route .app-brand-logo-wrap,
  .app-shell.app-project-details-route .app-brand-logo,
  .app-shell.app-project-details-route.app-scrolled .app-brand-logo-wrap,
  .app-shell.app-project-details-route.app-scrolled .app-brand-logo {
    width: 42px !important;
    height: 42px !important;
    min-width: 42px !important;
    min-height: 42px !important;
    max-width: 42px !important;
    max-height: 42px !important;
  }
}
/* =========================================================
   HARD FIX: MAIN DILG HEADER MUST ALWAYS STAY FIXED
   Paste at the VERY BOTTOM of src/styles/layout.css
   ========================================================= */

.app-header,
.app-shell .app-header,
.app-scrolled .app-header,
.app-project-details-route .app-header,
.app-project-details-route.app-scrolled .app-header {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;

  z-index: 2147483600 !important;

  width: 100vw !important;
  min-height: 74px !important;
  height: 74px !important;
  max-height: 74px !important;

  margin: 0 !important;
  padding: 9px 12px !important;

  transform: none !important;
  translate: none !important;
  opacity: 1 !important;
  visibility: visible !important;
  will-change: auto !important;
  backface-visibility: hidden !important;
}

.app-shell,
.app-project-details-route {
  padding-top: 74px !important;
}

@supports (padding-top: env(safe-area-inset-top)) {
  .app-header,
  .app-shell .app-header,
  .app-scrolled .app-header,
  .app-project-details-route .app-header,
  .app-project-details-route.app-scrolled .app-header {
    min-height: calc(74px + env(safe-area-inset-top)) !important;
    height: calc(74px + env(safe-area-inset-top)) !important;
    max-height: calc(74px + env(safe-area-inset-top)) !important;
    padding-top: calc(9px + env(safe-area-inset-top)) !important;
  }

  .app-shell,
  .app-project-details-route {
    padding-top: calc(74px + env(safe-area-inset-top)) !important;
  }
}
/* =========================================================
   PORTAL-MOUNTED MAIN HEADER FIX
   Paste at the VERY BOTTOM of src/styles/layout.css

   The DILG header is now rendered directly under body,
   so it can no longer scroll with .app-shell/page content.
   ========================================================= */

body > .app-header,
body > .app-header.app-header-scrolled {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;

  z-index: 2147483600 !important;

  width: 100vw !important;
  margin: 0 !important;
  border-radius: 0 !important;

  transform: none !important;
  translate: none !important;
  opacity: 1 !important;
  visibility: visible !important;
  pointer-events: auto !important;
  will-change: auto !important;
  backface-visibility: hidden !important;
}

/* Keep normal desktop shrink behavior using the new header class */
body > .app-header.app-header-scrolled {
  padding-top: 8px !important;
  padding-bottom: 8px !important;
  box-shadow: 0 10px 26px rgba(15, 23, 42, 0.13) !important;
}

body > .app-header.app-header-scrolled .app-brand-logo-wrap,
body > .app-header.app-header-scrolled .app-brand-logo {
  width: 42px !important;
  height: 42px !important;
}

body > .app-header.app-header-scrolled .app-brand-unit {
  max-height: 0 !important;
  margin-top: 0 !important;
  opacity: 0 !important;
}

/* On real phones, do not shrink the DILG header */
@media (max-width: 900px) {
  body > .app-header,
  body > .app-header.app-header-scrolled {
    min-height: 74px !important;
    height: 74px !important;
    max-height: 74px !important;

    padding: 9px 12px !important;

    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.16) !important;
    transition: none !important;
  }

  body > .app-header .app-brand-logo-wrap,
  body > .app-header .app-brand-logo,
  body > .app-header.app-header-scrolled .app-brand-logo-wrap,
  body > .app-header.app-header-scrolled .app-brand-logo {
    width: 46px !important;
    height: 46px !important;
    min-width: 46px !important;
    min-height: 46px !important;
    max-width: 46px !important;
    max-height: 46px !important;
  }

  body > .app-header .app-brand-unit,
  body > .app-header.app-header-scrolled .app-brand-unit {
    display: none !important;
  }

  body > .app-header .app-user-avatar,
  body > .app-header.app-header-scrolled .app-user-avatar {
    width: 35px !important;
    height: 35px !important;
  }

  .app-shell {
    padding-top: 74px !important;
  }
}

/* Safe area for iPhone / PWA */
@supports (padding-top: env(safe-area-inset-top)) {
  @media (max-width: 900px) {
    body > .app-header,
    body > .app-header.app-header-scrolled {
      min-height: calc(74px + env(safe-area-inset-top)) !important;
      height: calc(74px + env(safe-area-inset-top)) !important;
      max-height: calc(74px + env(safe-area-inset-top)) !important;
      padding-top: calc(9px + env(safe-area-inset-top)) !important;
    }

    .app-shell {
      padding-top: calc(74px + env(safe-area-inset-top)) !important;
    }
  }
}

/* =========================================================
   FINAL GLOBAL MOBILE SMOOTHNESS PASS
   Purpose: lighter real-phone scrolling without changing UI.
   ========================================================= */

@media (max-width: 900px) {
  html,
  body,
  #root {
    -webkit-overflow-scrolling: touch !important;
  }

  body {
    overscroll-behavior-y: contain !important;
  }

  body > .app-header,
  body > .app-header.app-header-scrolled {
    transform: translate3d(0, 0, 0) !important;
    -webkit-transform: translate3d(0, 0, 0) !important;
    backface-visibility: hidden !important;
    -webkit-backface-visibility: hidden !important;
    contain: layout style paint !important;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.14) !important;
  }

  .app-main {
    isolation: isolate !important;
  }

  .app-mobile-nav,
  .app-mobile-nav-scroll {
    transform: translate3d(0, 0, 0) !important;
    -webkit-transform: translate3d(0, 0, 0) !important;
    backface-visibility: hidden !important;
    -webkit-backface-visibility: hidden !important;
  }

  .app-mobile-nav {
    contain: layout style paint !important;
  }

  .app-mobile-nav-scroll {
    box-shadow:
      0 10px 24px rgba(15, 23, 42, 0.18),
      0 4px 10px rgba(15, 23, 42, 0.11) !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }

  .app-mobile-nav-item,
  .app-mobile-nav-icon,
  .app-mobile-nav-label {
    backface-visibility: hidden !important;
    -webkit-backface-visibility: hidden !important;
  }

  .app-mobile-nav-item:active {
    transform: scale(0.985) !important;
  }

  button,
  a,
  input,
  select,
  textarea {
    touch-action: manipulation;
  }

  .app-nav-link,
  .app-logout-button,
  .app-brand-logo-wrap,
  .app-brand-logo {
    will-change: auto !important;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    scroll-behavior: auto !important;
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
  }
}

/* =========================================================
   FINAL MOBILE NAV SHADOW POLISH
   Softer rounded shadow; removes the heavy rectangular band
   under the iOS-style bottom navigation.
========================================================= */

@media (max-width: 900px) {
  .app-mobile-nav {
    left: 10px !important;
    right: 10px !important;
    bottom: 7px !important;
    height: 74px !important;
    overflow: visible !important;
    background: transparent !important;
    box-shadow: none !important;
    filter: drop-shadow(0 10px 16px rgba(15, 23, 42, 0.16)) !important;
    -webkit-filter: drop-shadow(0 10px 16px rgba(15, 23, 42, 0.16)) !important;
  }

  .app-mobile-nav-scroll {
    border: 1px solid rgba(226, 232, 240, 0.94) !important;
    border-radius: 28px !important;
    background: rgba(255, 255, 255, 0.985) !important;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 1px 2px rgba(15, 23, 42, 0.04) !important;
  }

  .app-mobile-nav-item.active {
    background: #fff7ed !important;
    color: #ea580c !important;
    box-shadow: none !important;
  }
}

@media (max-width: 420px) {
  .app-mobile-nav {
    left: 7px !important;
    right: 7px !important;
    bottom: 7px !important;
    height: 72px !important;
    filter: drop-shadow(0 9px 14px rgba(15, 23, 42, 0.15)) !important;
    -webkit-filter: drop-shadow(0 9px 14px rgba(15, 23, 42, 0.15)) !important;
  }

  .app-mobile-nav-scroll {
    border-radius: 24px !important;
  }
}


/* =========================================================
   ANDROID CHROME SINGLE-FINGER SCROLL FIX
   Keeps the fixed header/bottom nav, but lets page content receive
   normal vertical pan gestures on Android Chrome/PWA.
   ========================================================= */

@media (max-width: 900px) {
  html,
  body,
  #root {
    height: auto !important;
    min-height: 100% !important;
    overflow-x: hidden !important;
    overflow-y: auto !important;
    touch-action: pan-y pinch-zoom !important;
    overscroll-behavior-y: auto !important;
  }

  body {
    position: relative !important;
    -webkit-overflow-scrolling: touch !important;
  }

  #root,
  .app-shell,
  .app-main,
  .app-content,
  .main-content,
  .page-content,
  .pu-page,
  .pu-form-card,
  .pu-update-section {
    height: auto !important;
    max-height: none !important;
    overflow-y: visible !important;
    touch-action: pan-y pinch-zoom !important;
    overscroll-behavior-y: auto !important;
  }

  .app-shell {
    min-height: 100dvh !important;
  }

  .app-main {
    min-height: calc(100dvh - var(--app-header-live-h, var(--app-header-h))) !important;
    padding-bottom: calc(112px + env(safe-area-inset-bottom, 0px)) !important;
  }

  .app-header,
  body > .app-header,
  .app-mobile-nav,
  .app-mobile-nav-scroll {
    touch-action: pan-y pinch-zoom !important;
  }

  button,
  a,
  input,
  select,
  textarea,
  .app-mobile-nav-item,
  .pu-action-btn,
  .pu-choice-card,
  .pu-main-save-btn,
  .pu-date-picker-proxy {
    touch-action: manipulation !important;
  }

  .pu-modal-overlay,
  .pu-save-modal,
  .pu-success-modal {
    touch-action: auto !important;
  }
}




/* =========================
   PMS10 RESCUE RESTORE MERGE
   Safe desktop polish only. Does not override hero merge/sticky positioning.
========================= */

@media (min-width: 901px) {
  :root {
    --pms10-desktop-bg: #f3f7fb;
    --pms10-card-shadow: 0 12px 32px rgba(15, 23, 42, 0.07);
    --pms10-card-border: rgba(148, 163, 184, 0.18);
  }

  body,
  #root {
    background: var(--pms10-desktop-bg) !important;
  }

  .app-header {
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.10);
  }

  .app-main {
    background: transparent;
  }
}

/* =========================
   PMS10 REMOVE SIDEBAR ARTIFACTS FIX
   Removes sidebar experiment leftovers while keeping original hero/header merge.
========================= */

@media (min-width: 901px) {
  .app-sidebar-toggle,
  .app-sidebar-trademark {
    display: none !important;
  }

  .app-shell.app-sidebar-collapsed {
    padding-left: inherit;
  }
}



/* =========================
   PMS10 MOBILE NAVBAR SQUARE BLUE FIX
   Mobile only. Full-width rectangular blue bottom bar, no floating frame.
========================= */

@media (max-width: 900px) {
  .app-mobile-nav {
    position: fixed !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    width: 100% !important;
    max-width: none !important;
    height: calc(64px + env(safe-area-inset-bottom)) !important;
    min-height: calc(64px + env(safe-area-inset-bottom)) !important;
    max-height: calc(64px + env(safe-area-inset-bottom)) !important;
    margin: 0 !important;
    padding: 6px 8px calc(6px + env(safe-area-inset-bottom)) !important;

    border: 0 !important;
    border-radius: 0 !important;
    outline: 0 !important;

    background:
      linear-gradient(135deg, #123f73 0%, #18599d 56%, #2368b5 100%) !important;

    -webkit-backdrop-filter: none !important;
    backdrop-filter: none !important;

    box-shadow:
      0 -10px 26px rgba(15, 48, 87, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.12) !important;

    overflow: hidden !important;
    z-index: 1200 !important;
  }

  .app-mobile-nav::before,
  .app-mobile-nav::after {
    display: none !important;
    content: none !important;
    background: transparent !important;
    box-shadow: none !important;
    border: 0 !important;
  }

  .app-mobile-nav a,
  .app-mobile-nav button,
  .app-mobile-nav-link {
    position: relative !important;
    z-index: 1 !important;

    flex: 1 1 0 !important;
    min-width: 0 !important;
    min-height: 52px !important;
    height: 52px !important;
    max-height: 52px !important;

    margin: 0 !important;
    padding: 5px 2px !important;
    border: 0 !important;
    border-radius: 0 !important;
    outline: 0 !important;

    color: rgba(255, 255, 255, 0.78) !important;
    background: transparent !important;
    box-shadow: none !important;
    transform: none !important;
  }

  .app-mobile-nav a.active,
  .app-mobile-nav-link.active,
  .app-mobile-nav .active {
    color: #ffffff !important;
    background: rgba(255, 255, 255, 0.12) !important;
    border-radius: 12px !important;
    box-shadow: none !important;
  }

  .app-mobile-nav svg,
  .app-mobile-nav a svg,
  .app-mobile-nav button svg,
  .app-mobile-nav-link svg {
    width: 21px !important;
    height: 21px !important;
    color: currentColor !important;
    fill: currentColor !important;
    stroke: currentColor !important;
    filter: none !important;
    margin: 0 0 2px !important;
  }

  .app-mobile-nav span,
  .app-mobile-nav-label,
  .app-mobile-nav a span,
  .app-mobile-nav button span {
    color: currentColor !important;
    font-size: 0.64rem !important;
    line-height: 1 !important;
    font-weight: 900 !important;
  }

  .app-main {
    padding-bottom: calc(82px + env(safe-area-inset-bottom)) !important;
  }
}

@media (max-width: 420px) {
  .app-mobile-nav {
    height: calc(62px + env(safe-area-inset-bottom)) !important;
    min-height: calc(62px + env(safe-area-inset-bottom)) !important;
    max-height: calc(62px + env(safe-area-inset-bottom)) !important;
    padding: 5px 6px calc(5px + env(safe-area-inset-bottom)) !important;
  }

  .app-mobile-nav a,
  .app-mobile-nav button,
  .app-mobile-nav-link {
    min-height: 52px !important;
    height: 52px !important;
    max-height: 52px !important;
  }

  .app-mobile-nav svg {
    width: 20px !important;
    height: 20px !important;
  }

  .app-mobile-nav span,
  .app-mobile-nav-label,
  .app-mobile-nav a span,
  .app-mobile-nav button span {
    font-size: 0.62rem !important;
  }

  .app-main {
    padding-bottom: calc(80px + env(safe-area-inset-bottom)) !important;
  }
}
